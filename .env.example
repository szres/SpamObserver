# Required: Telegram Bot Token from @BotFather
BOT_TOKEN=

# Required: Public URL where the webhook will be registered (e.g., https://yourdomain.com)
PUBLIC_URL=

# Optional: Webhook secret token (default: spamo-whsec)
WEBHOOK_SECRET=spamo-whsec

# Optional: Server port (default: 8080)
PORT=8080

# Optional: Admin credentials (defaults: admin/admin)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin

# Optional: JWT signing secret (auto-generated if empty)
JWT_SECRET=
